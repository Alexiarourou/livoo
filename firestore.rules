rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /notifications/{notifId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.type == 'answer_request'
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.userId is string
        && request.resource.data.postId is string;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /mail/{mailId} {
      allow read, write: if false;
    }

    match /waitlist/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'createdAt'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() < 320;
      allow read, update, delete: if false;
    }

    match /cityRequests/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['city', 'email', 'createdAt'])
        && request.resource.data.city is string
        && request.resource.data.email is string
        && request.resource.data.createdAt is timestamp
        && request.resource.data.city.size() > 0
        && request.resource.data.city.size() < 200
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() < 320;
      allow read, update, delete: if false;
    }

    match /communityPosts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /likes/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow write: if request.auth != null;

        match /likes/{likeUserId} {
          allow read: if true;
          allow write: if request.auth != null && request.auth.uid == likeUserId;
        }

        match /replies/{replyId} {
          allow read: if true;
          allow write: if request.auth != null;
        }
      }
    }
  }
}
