rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /notifications/{notifId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.type == 'answer_request'
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.userId is string
        && request.resource.data.postId is string;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /mail/{mailId} {
      allow read, write: if false;
    }

    // Used by community-portal.html (modular Firestore client)
    match /communityPosts/{postId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && (request.resource.data.authorId == request.auth.uid
            || request.resource.data.author == request.auth.uid)
        && request.resource.data.city is string
        && request.resource.data.category is string;

      allow delete: if request.auth != null
        && (resource.data.authorId == request.auth.uid
            || resource.data.author == request.auth.uid);

      allow update: if request.auth != null && (
        resource.data.authorId == request.auth.uid
        || resource.data.author == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['commentCount', 'upvoteCount', 'viewCount', 'pinnedCommentId'])
      );

      match /comments/{commentId} {
        allow read: if true;
        allow write: if request.auth != null;

        match /likes/{likeUserId} {
          allow read: if true;
          allow create, delete: if request.auth != null && request.auth.uid == likeUserId;
        }

        match /replies/{replyId} {
          allow read: if true;
          allow write: if request.auth != null;
        }
      }

      match /upvotes/{userId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
